# Financial Explainable AI Assistant Configuration

# Google Gemini API Key - Get one from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key - Get one from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Backend URL for Streamlit
FINANCIAL_XAI_BACKEND_URL=http://127.0.0.1:5000/chat

# Chat history persistence (Streamlit + CLI)
FINANCIAL_XAI_CHAT_HISTORY_DIR=./data/chat_history
FINANCIAL_XAI_CHAT_HISTORY_AUTOSAVE=true

# Backend turn-by-turn logging (JSONL)
FINANCIAL_XAI_CHAT_LOG_ENABLED=true
FINANCIAL_XAI_CHAT_LOG_PATH=./data/chat_history/turns.jsonl
